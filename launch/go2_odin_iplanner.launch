<launch>
  <!-- iPlanner control bringup only.
       External hardware/SDK launches (Odin driver, Go2 bridge) are owned by
       scripts/start_go2_iplanner.sh and their native workspaces. This launch
       starts iPlanner plus the AEE bridge/controller pieces needed for
       /state_estimation, /registered_scan, /path, and /cmd_vel. AEE
       localPlanner and terrain analysis are intentionally not launched here. -->

  <!-- Package launch toggles -->
  <arg name="start_loam_interface" default="true" />
  <arg name="start_iplanner" default="true" />
  <arg name="start_path_follower" default="true" />
  <arg name="start_rviz" default="false" />

  <!-- Runtime configuration -->
  <arg name="config" default="go2_odin" />
  <arg name="joyTopic" default="/go2/joy" />
  <arg name="sensorOffsetX" default="0.325" />
  <arg name="sensorOffsetY" default="0" />
    <arg name="maxSpeed" default="1.0" />
  <arg name="autonomyMode" default="true" />
  <arg name="autonomySpeed" default="1.0" />
  <arg name="joyToSpeedDelay" default="2.0" />

  <group if="$(arg start_loam_interface)">
    <include file="$(find loam_interface)/launch/loam_interface_odin.launch" />
  </group>


  <group if="$(arg start_iplanner)">
    <node pkg="iplanner_node" type="iplanner_node.py" name="iplanner_node" output="screen" required="true">
      <rosparam command="load" file="$(find iplanner_node)/config/$(arg config).yaml" />
      <remap from="/joy" to="$(arg joyTopic)" />
    </node>
  </group>

  <group if="$(arg start_path_follower)">
    <node pkg="local_planner" type="pathFollower" name="pathFollower" output="screen" required="false">
      <remap from="/joy" to="$(arg joyTopic)" />

      <!-- Geometry / drive -->
      <param name="sensorOffsetX" value="$(arg sensorOffsetX)" />
      <param name="sensorOffsetY" value="$(arg sensorOffsetY)" />
      <param name="pubSkipNum" type="int" value="1" />
      <param name="twoWayDrive" type="bool" value="false" />

      <!-- Smooth Go2 tracking parameters copied from tuned AEE launch -->
      <param name="lookAheadDis" type="double" value="1.5" />
      <param name="yawRateGain" type="double" value="4.5" />
      <param name="stopYawRateGain" type="double" value="4.5" />
      <param name="maxYawRate" type="double" value="90.0" />
      <param name="noRotSpeed" type="double" value="0.60" />
      <param name="goalCloseDis" type="double" value="1.2" />

      <!-- Speed / acceleration -->
      <param name="maxSpeed" value="$(arg maxSpeed)" />
      <param name="maxAccel" type="double" value="2.0" />

      <!-- Direction switching -->
      <param name="switchTimeThre" type="double" value="1.0" />
      <param name="dirDiffThre" type="double" value="0.15" />
      <param name="omniDirDiffThre" type="double" value="1.5" />

      <!-- Stop / slowdown distances -->
      <param name="stopDisThre" type="double" value="0.45" />
      <param name="slowDwnDisThre" type="double" value="0.85" />

      <!-- Incline-based slowdown / stop disabled for Odin+iPlanner bringup -->
      <param name="useInclRateToSlow" type="bool" value="false" />
      <param name="inclRateThre" type="double" value="120.0" />
      <param name="slowRate1" type="double" value="0.25" />
      <param name="slowRate2" type="double" value="0.5" />
      <param name="slowTime1" type="double" value="2.0" />
      <param name="slowTime2" type="double" value="2.0" />
      <param name="useInclToStop" type="bool" value="false" />
      <param name="inclThre" type="double" value="45.0" />
      <param name="stopTime" type="double" value="5.0" />

      <!-- Rotation at stop/goal -->
      <param name="noRotAtStop" type="bool" value="false" />
      <param name="noRotAtGoal" type="bool" value="true" />

      <!-- Autonomy speed fallback -->
      <param name="autonomyMode" value="$(arg autonomyMode)" />
      <param name="autonomySpeed" value="$(arg autonomySpeed)" />
      <param name="joyToSpeedDelay" value="$(arg joyToSpeedDelay)" />
    </node>
  </group>

  <!-- TF needed by iPlanner goal transform and pathFollower/AEE frame conventions. -->
  <node pkg="tf" type="static_transform_publisher" name="vehicleTransPublisher"
        args="-$(arg sensorOffsetX) -$(arg sensorOffsetY) 0 0 0 0 /sensor /vehicle 1000" />
  <node pkg="tf" type="static_transform_publisher" name="sensorTransPublisher"
        args="0.00137656 0.02511966 -0.00162311 -1.58066166 0.00707324 -1.57152611 /sensor /camera 1000" />

  <group if="$(arg start_rviz)">
    <node type="rviz" name="iplanner_rviz" pkg="rviz" args="-d $(find iplanner_node)/rviz/default.rviz" respawn="false" />
  </group>
</launch>
